# ===========================================
# Admin Panel — Environment Variables Example
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
# For local Docker PostgreSQL:
DATABASE_URL="postgresql://YOU_USER:YOUR_PASSWORD@postgres:5432/admindashboard?schema=public"

# For remote PostgreSQL:
# DATABASE_URL="postgresql://YOU_USER:YOUR_PASSWORD@<DATABASE_HOST>:5432/admindashboard?schema=public"

# -------------------------------------------
# Authentik OAuth
# -------------------------------------------
AUTHENTIK_CLIENT_ID="your-client-id"
AUTHENTIK_CLIENT_SECRET="your-client-secret"
AUTHENTIK_ISSUER="https://auth.example.com/application/o/admin-web/"

# -------------------------------------------
# NextAuth
# -------------------------------------------
NEXTAUTH_URL="https://admin.example.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Generate NEXTAUTH_SECRET with: openssl rand -base64 32

# -------------------------------------------
# Public API URLs
# -------------------------------------------
NEXT_PUBLIC_ADMIN_API_URL="https://admin.example.com"
NEXT_PUBLIC_PORTFOLIO_URL="https://portfolio.example.com"
