// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  avatar    String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  url         String
  status      String    @default("active")
  description String?
  thumbnail   String?
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  content     Json?
  settings    Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pages       Page[]
  images      Image[]
  builds      Build[]

  @@map("projects")
}

model Page {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  content   Json
  updatedAt DateTime @updatedAt

  @@unique([projectId, slug])
  @@map("pages")
}

model Image {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  path      String
  size      Int
  mimeType  String
  alt       String?
  createdAt DateTime @default(now())

  @@map("images")
}

model Build {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String    @default("pending")
  logs      String?
  triggeredBy String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@map("builds")
}
