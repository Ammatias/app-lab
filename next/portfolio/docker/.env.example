# ===========================================
# Portfolio — Environment Variables Example
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Admin Panel API
# -------------------------------------------
# For Docker (internal network):
NEXT_PUBLIC_ADMIN_API_URL="http://admin-panel:3000"

# For local development:
# NEXT_PUBLIC_ADMIN_API_URL="http://localhost:3001"

# For production:
# NEXT_PUBLIC_ADMIN_API_URL="https://admin.example.com"

# -------------------------------------------
# Data Source
# -------------------------------------------
# "api" - get data from Admin Panel API
# "static" - use local static data from /data
DATA_SOURCE="api"
